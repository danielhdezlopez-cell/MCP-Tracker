<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200">
  <defs>
    <radialGradient id="bg" cx="50%" cy="30%" r="70%">
      <stop offset="0%" stop-color="#3a2060"/>
      <stop offset="100%" stop-color="#080010"/>
    </radialGradient>
    <radialGradient id="gauntlet" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="#ffd700"/>
      <stop offset="100%" stop-color="#b8860b"/>
    </radialGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="4" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
  </defs>
  <circle cx="100" cy="100" r="100" fill="url(#bg)"/>
  <circle cx="100" cy="100" r="95" fill="none" stroke="#8844cc" stroke-width="2" opacity="0.6"/>
  <!-- Thanos body - massive frame -->
  <ellipse cx="100" cy="115" rx="40" ry="38" fill="#4a3068" stroke="#6644aa" stroke-width="2"/>
  <!-- Armor chest -->
  <ellipse cx="100" cy="110" rx="30" ry="28" fill="#2a1848" stroke="#8855bb" stroke-width="1.5"/>
  <!-- Infinity Gauntlet -->
  <ellipse cx="130" cy="118" rx="16" ry="20" fill="url(#gauntlet)" stroke="#ffd700" stroke-width="1.5" filter="url(#glow)"/>
  <!-- Infinity Stones -->
  <circle cx="124" cy="108" r="4" fill="#8844ff" filter="url(#glow)"/>
  <circle cx="136" cy="108" r="4" fill="#ff4422" filter="url(#glow)"/>
  <circle cx="130" cy="116" r="4" fill="#44aaff" filter="url(#glow)"/>
  <circle cx="122" cy="122" r="4" fill="#44ff44" filter="url(#glow)"/>
  <circle cx="138" cy="122" r="4" fill="#ff8800" filter="url(#glow)"/>
  <circle cx="130" cy="130" r="4" fill="#ff44aa" filter="url(#glow)"/>
  <!-- Head - large chin, bald -->
  <ellipse cx="100" cy="68" rx="30" ry="34" fill="#5a3878" stroke="#8855bb" stroke-width="1.5"/>
  <!-- Chin lines (Thanos' characteristic chin) -->
  <path d="M82,88 Q100,98 118,88" fill="#3a2058" stroke="#6644aa" stroke-width="2"/>
  <line x1="92" y1="88" x2="92" y2="96" stroke="#6644aa" stroke-width="1.5"/>
  <line x1="100" y1="90" x2="100" y2="98" stroke="#6644aa" stroke-width="1.5"/>
  <line x1="108" y1="88" x2="108" y2="96" stroke="#6644aa" stroke-width="1.5"/>
  <!-- Eyes -->
  <ellipse cx="90" cy="64" rx="6" ry="5" fill="#cc2222"/>
  <ellipse cx="110" cy="64" rx="6" ry="5" fill="#cc2222"/>
  <circle cx="90" cy="64" r="2.5" fill="#ff0000" filter="url(#glow)"/>
  <circle cx="110" cy="64" r="2.5" fill="#ff0000" filter="url(#glow)"/>
  <!-- Name -->
  <text x="100" y="172" text-anchor="middle" font-family="monospace" font-size="13" fill="#aa66ff" font-weight="bold" letter-spacing="2">THANOS</text>
</svg>
