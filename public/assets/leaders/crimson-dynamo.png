<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200">
  <defs>
    <radialGradient id="bg" cx="50%" cy="40%" r="60%">
      <stop offset="0%" stop-color="#b22222"/>
      <stop offset="100%" stop-color="#3a0000"/>
    </radialGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="3" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
  </defs>
  <circle cx="100" cy="100" r="100" fill="url(#bg)"/>
  <circle cx="100" cy="100" r="95" fill="none" stroke="#ff4444" stroke-width="2" opacity="0.6"/>
  <!-- Dynamo armor chest piece -->
  <ellipse cx="100" cy="95" rx="35" ry="42" fill="#8b0000" stroke="#ff6666" stroke-width="1.5"/>
  <ellipse cx="100" cy="90" rx="20" ry="25" fill="#cc0000" stroke="#ff8888" stroke-width="1"/>
  <!-- Energy core -->
  <circle cx="100" cy="95" r="12" fill="#ff2222" filter="url(#glow)" opacity="0.9"/>
  <circle cx="100" cy="95" r="7" fill="#ffaaaa"/>
  <!-- Helmet -->
  <ellipse cx="100" cy="58" rx="28" ry="30" fill="#6b0000" stroke="#ff4444" stroke-width="1.5"/>
  <ellipse cx="100" cy="54" rx="18" ry="12" fill="#ff2222" opacity="0.7"/>
  <!-- Shoulder pads -->
  <ellipse cx="65" cy="88" rx="18" ry="12" fill="#8b0000" stroke="#ff4444" stroke-width="1" transform="rotate(-15,65,88)"/>
  <ellipse cx="135" cy="88" rx="18" ry="12" fill="#8b0000" stroke="#ff4444" stroke-width="1" transform="rotate(15,135,88)"/>
  <!-- Name -->
  <text x="100" y="162" text-anchor="middle" font-family="monospace" font-size="11" fill="#ff6666" font-weight="bold" letter-spacing="1">CRIMSON</text>
  <text x="100" y="176" text-anchor="middle" font-family="monospace" font-size="11" fill="#ff6666" font-weight="bold" letter-spacing="1">DYNAMO</text>
</svg>
